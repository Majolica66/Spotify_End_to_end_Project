{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotifyadfpipeline"
		},
		"ls_sink_parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_sink_parquet'"
		},
		"ls_src_azuresql_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_src_azuresql_db'"
		},
		"ls_srclookup_json_dynamic_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_srclookup_json_dynamic'"
		},
		"ls_sink_parquet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyazurestoragesink.dfs.core.windows.net/"
		},
		"ls_src_azuresql_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azuresqlserverdev.database.windows.net"
		},
		"ls_src_azuresql_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-1952606"
		},
		"ls_src_azuresql_db_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admin11"
		},
		"ls_srclookup_json_dynamic_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyazurestoragesink.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "spotifyadfpipeline_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_sink_parquet_accountKey": {
						"value": "[parameters('ls_sink_parquet_accountKey')]"
					},
					"ls_src_azuresql_db_password": {
						"value": "[parameters('ls_src_azuresql_db_password')]"
					},
					"ls_srclookup_json_dynamic_accountKey": {
						"value": "[parameters('ls_srclookup_json_dynamic_accountKey')]"
					},
					"ls_sink_parquet_properties_typeProperties_url": {
						"value": "[parameters('ls_sink_parquet_properties_typeProperties_url')]"
					},
					"ls_src_azuresql_db_properties_typeProperties_server": {
						"value": "[parameters('ls_src_azuresql_db_properties_typeProperties_server')]"
					},
					"ls_src_azuresql_db_properties_typeProperties_database": {
						"value": "[parameters('ls_src_azuresql_db_properties_typeProperties_database')]"
					},
					"ls_src_azuresql_db_properties_typeProperties_userName": {
						"value": "[parameters('ls_src_azuresql_db_properties_typeProperties_userName')]"
					},
					"ls_srclookup_json_dynamic_properties_typeProperties_url": {
						"value": "[parameters('ls_srclookup_json_dynamic_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}