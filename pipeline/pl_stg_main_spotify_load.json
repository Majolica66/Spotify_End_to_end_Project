{
	"name": "pl_stg_spotify_load",
	"properties": {
		"activities": [
			{
				"name": "IfLoadType",
				"type": "IfCondition",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@equals(pipeline().parameters.Loadtype, 'Incremental')",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "Execute Pipeline Backfilling",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pl_stg_backfilling",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"BackfillStartDate": {
										"value": "@pipeline().parameters.BackfillStartDate",
										"type": "Expression"
									},
									"BackfillEndDate": {
										"value": "@pipeline().parameters.BackfillEndDate",
										"type": "Expression"
									},
									"Loadtype": {
										"value": "@pipeline().parameters.Loadtype",
										"type": "Expression"
									}
								}
							}
						}
					],
					"ifTrueActivities": [
						{
							"name": "Execute Pipeline Incremental",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pl_stg_Incremental_load",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"Loadtype": {
										"value": "@pipeline().parameters.Loadtype",
										"type": "Expression"
									}
								}
							}
						}
					]
				}
			}
		],
		"parameters": {
			"Loadtype": {
				"type": "string",
				"defaultValue": "Incremental"
			},
			"BackfillStartDate": {
				"type": "string",
				"defaultValue": "Null"
			},
			"BackfillEndDate": {
				"type": "string",
				"defaultValue": "Null"
			}
		},
		"annotations": []
	}
}